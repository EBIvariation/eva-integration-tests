<settings>

    <profiles>

        <profile>
            <id>docker</id>

            <properties>
                <eva.evapro.jdbc.url>jdbc:postgresql://localhost:5432/metadata_db</eva.evapro.jdbc.url>
                <eva.evapro.user>metadata_db_user</eva.evapro.user>
                <eva.evapro.password>metadata_db_pass</eva.evapro.password>

                <submission-ws.admin-user>eva-submission-ws-admin-user</submission-ws.admin-user>
                <submission-ws.admin-password>eva-submission-ws-admin-pass</submission-ws.admin-password>

                <eva.helpdesk-email>eva-helpdesk@ebi.ac.uk</eva.helpdesk-email>
                <mailhog.email-messages>http://localhost:8025/api/v1/messages</mailhog.email-messages>

                <eva.mongo.host>localhost:27017</eva.mongo.host>
                <eva.mongo.user></eva.mongo.user>
                <eva.mongo.passwd></eva.mongo.passwd>
                <eva.mongo.collections.variants>variants_2_0</eva.mongo.collections.variants>
                <eva.mongo.collections.files>files_2_0</eva.mongo.collections.files>
                <eva.mongo.collections.annotation-metadata>annotationMetadata_2_0</eva.mongo.collections.annotation-metadata>
                <eva.mongo.collections.features>features_2_0</eva.mongo.collections.features>
                <eva.mongo.collections.annotations>annotations_2_0</eva.mongo.collections.annotations>
                <eva.accession.mongo.database>eva_accession_sharded</eva.accession.mongo.database>
                <eva.accession.mongo.human.database>eva_accession_human_sharded</eva.accession.mongo.human.database>

                <contig-alias.url>http://localhost:8081/contig-alias</contig-alias.url>
                <contig-alias.admin-user></contig-alias.admin-user>
                <contig-alias.admin-password></contig-alias.admin-password>
            </properties>

        </profile>

    </profiles>

</settings>
