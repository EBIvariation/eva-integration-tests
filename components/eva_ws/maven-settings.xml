<settings>

    <profiles>
        <profile>
            <id>docker</id>

            <properties>
                <eva.mongo.host>mongo_db:27017</eva.mongo.host>
                <eva.mongo.user></eva.mongo.user>
                <eva.mongo.passwd></eva.mongo.passwd>
                <eva.mongo.auth.db>admin</eva.mongo.auth.db>
                <eva.mongo.read-preference>secondaryPreferred</eva.mongo.read-preference>
                <eva.mongo.collections.variants>variants_2_0</eva.mongo.collections.variants>
                <eva.mongo.collections.files>files_2_0</eva.mongo.collections.files>
                <eva.mongo.collections.annotation-metadata>annotationMetadata_2_0</eva.mongo.collections.annotation-metadata>
                <eva.mongo.collections.features>features_2_0</eva.mongo.collections.features>
                <eva.mongo.collections.annotations>annotations_2_0</eva.mongo.collections.annotations>
                <eva.accession.mongo.database>eva_accession_sharded</eva.accession.mongo.database>

                <eva.evapro.jdbc.url>jdbc:postgresql://postgres_db:5432/metadata_db</eva.evapro.jdbc.url>
                <eva.evapro.user>metadata_db_user</eva.evapro.user>
                <eva.evapro.password>metadata_db_pass</eva.evapro.password>

                <eva.count-stats.username>count_stats_user</eva.count-stats.username>
                <eva.count-stats.password>count_stats_pass</eva.count-stats.password>
            </properties>
        </profile>

    </profiles>

</settings>
